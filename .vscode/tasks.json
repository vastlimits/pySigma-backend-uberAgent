        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "Convert Rules (uberagent, 7.4)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "source ~/sigma-cli/bin/activate && '${workspaceFolder}/convert-rules.sh' '${workspaceFolder}/rules' uberagent-7.4.0 7.4"
      ],
      "options": {
        "cwd": "${workspaceFolder}/out"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [
        "$python"
      ]
    }
  ]
